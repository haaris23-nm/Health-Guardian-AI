# HealthGuardian AI / HealthMate Flask Backend Environment Variables

# Environment setup
FLASK_ENV=production
PORT=5000

# Security secret keys
JWT_SECRET_KEY=your_super_secret_jwt_key_here

# Google Gemini API Key
GEMINI_API_KEY=your_google_gemini_api_key_here

# Database connection URL (SQLite or PostgreSQL / MySQL)
DATABASE_URL=sqlite:///healthguardian.db

# Frontend Application URL
APP_URL=https://your-frontend-domain.onrender.com
